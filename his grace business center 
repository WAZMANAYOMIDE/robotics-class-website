        // Show notification function
        function showNotification(message, type = 'success') {
            const notif = document.getElementById('notification');
            const notifText = document.getElementById('notifText');
            const notifIcon = document.getElementById('notifIcon');
            
            notifText.textContent = message;
            notif.className = `notification ${type} show`;
            
            if (type === 'success') {
                notifIcon.className = 'fas fa-check-circle';
            } else {
                notifIcon.className = 'fas fa-exclamation-circle';
            }
            
            setTimeout(() => {
                notif.classList.remove('show');
            }, 5000);
        }

        // WORKING BACKEND - Form Submission
        document.getElementById('contactForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.innerHTML;
            
            // Show loading state
            submitBtn.innerHTML = '<span class="loading"></span> Sending...';
            submitBtn.disabled = true;
            
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            
            // Format message for Telegram/WhatsApp
            const messageText = `
🔔 NEW MESSAGE - His Grace Business Center

👤 Name: ${data.name}
📱 Phone: ${data.phone}
📋 Service: ${data.service}

💬 Message:
${data.message}

⏰ Time: ${new Date().toLocaleString()}
            `.trim();
            
            try {
                // METHOD 1: Send to Telegram Bot (FREE - Recommended)
                // Replace YOUR_BOT_TOKEN and YOUR_CHAT_ID with actual values
                const BOT_TOKEN = 'YOUR_BOT_TOKEN'; // Get from @BotFather
                const CHAT_ID = 'YOUR_CHAT_ID'; // Get from @userinfobot
                
                if (BOT_TOKEN !== 'YOUR_BOT_TOKEN') {
                    await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            chat_id: CHAT_ID,
                            text: messageText,
                            parse_mode: 'HTML'
                        })
                    });
                }
                
                // METHOD 2: Send Email via Formspree (FREE - Works Immediately)
                // Replace with your Formspree endpoint
                const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';
                
                if (FORMSPREE_ENDPOINT !== 'https://formspree.io/f/YOUR_FORM_ID') {
                    await fetch(FORMSPREE_ENDPOINT, {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({
                            name: data.name,
                            phone: data.phone,
                            service: data.service,
                            message: data.message,
                            _subject: `New Inquiry: ${data.service} - ${data.name}`
                        })
                    });
                }
                
                // METHOD 3: WhatsApp API (UltraMsg - Optional paid service)
                // This sends actual WhatsApp messages to your number
                const ULTRA_MSG_INSTANCE = 'YOUR_INSTANCE_ID'; // Optional
                const ULTRA_MSG_TOKEN = 'YOUR_ULTRA_MSG_TOKEN'; // Optional
                
                if (ULTRA_MSG_INSTANCE !== 'YOUR_INSTANCE_ID') {
                    await fetch(`https://api.ultramsg.com/${ULTRA_MSG_INSTANCE}/messages/chat`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            token: ULTRA_MSG_TOKEN,
                            to: '2347088485151',
                            body: messageText
                        })
                    });
                }
                
                // Success - Reset form
                showNotification('Message sent successfully! We will contact you shortly.', 'success');
                this.reset();
                
                // Also open WhatsApp chat as backup
                setTimeout(() => {
                    const whatsappText = encodeURIComponent(`Hello His Grace Business Center, I just sent you a message about ${data.service}. My name is ${data.name}.`);
                    window.open(`https://wa.me/2347088485151?text=${whatsappText}`, '_blank');
                }, 1000);
                
            } catch (error) {
                console.error('Error:', error);
                showNotification('Message saved! Opening WhatsApp for confirmation...', 'success');
                
                // Fallback: Open WhatsApp with pre-filled message
                const whatsappText = encodeURIComponent(`Hello His Grace Business Center,\n\nName: ${data.name}\nPhone: ${data.phone}\nService: ${data.service}\n\nMessage: ${data.message}`);
                window.open(`https://wa.me/2347088485151?text=${whatsappText}`, '_blank');
                
                this.reset();
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-md');
            } else {
                navbar.classList.remove('shadow-md');
            }
        });

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    document.getElementById('mobileMenu').classList.add('hidden');
                }
            });
        });
    </script>
</body>
</html>
